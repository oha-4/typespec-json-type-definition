{
  "name": "typespec-json-type-definition",
  "version": "0.1.0",
  "description": "TypeSpec emitter that produces JSON Type Definition (RFC 8927) schemas",
  "keywords": [
    "typespec",
    "emitter",
    "json-type-definition",
    "jtd",
    "rfc8927",
    "json"
  ],
  "author": "Yoshito Ohata",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./testing": {
      "types": "./dist/src/testing/index.d.ts",
      "default": "./dist/src/testing/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/src/**",
    "!dist/test/**",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oha-4/typespec-json-type-definition.git"
  },
  "bugs": {
    "url": "https://github.com/oha-4/typespec-json-type-definition/issues"
  },
  "homepage": "https://github.com/oha-4/typespec-json-type-definition#readme",
  "scripts": {
    "clean": "rm -rf dist coverage tsp-output samples/output",
    "build": "tsc -p .",
    "watch": "tsc -p . --watch",
    "format": "prettier --write . && tsp format \"samples/**/*.tsp\"",
    "format:check": "prettier --check . && tsp format --check \"samples/**/*.tsp\"",
    "lint": "tsc -p . --noEmit",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "coverage": "npm run build && vitest run --coverage",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@typespec/compiler": ">=1.12.0 <2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@typespec/compiler": "^1.12.0",
    "@vitest/coverage-v8": "^4.1.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
